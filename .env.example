# MAIT — Meta Ads Intelligence Tool
# Copy to .env.local and fill in values

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Apify
APIFY_API_TOKEN=
APIFY_ACTOR_ID=apify/meta-ads-scraper

# AI Tagging via OpenRouter (optional — ads get auto-tagged if set)
OPENROUTER_API_KEY=

# Cron security (optional — Vercel injects this automatically)
CRON_SECRET=

# Admin JWT signing secret — REQUIRED for /admin. Must be >= 32 chars.
# Generate with: openssl rand -base64 48
ADMIN_JWT_SECRET=

# Meta Marketing API (Phase 2)
META_APP_ID=
META_APP_SECRET=
