# MAIT — Meta Ads Intelligence Tool
# Copy to .env.local and fill in values

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Apify
APIFY_API_TOKEN=
APIFY_ACTOR_ID=apify/meta-ads-scraper

# AI Tagging via OpenRouter (optional — ads get auto-tagged if set)
OPENROUTER_API_KEY=

# Cron security (optional — Vercel injects this automatically)
CRON_SECRET=

# Admin JWT signing secret — REQUIRED for /admin. Must be >= 32 chars.
# Generate with: openssl rand -base64 48
ADMIN_JWT_SECRET=

# Meta Marketing API (Phase 2)
META_APP_ID=
META_APP_SECRET=

# Sentry (error tracking + alerts). Without these the app runs fine and
# Sentry stays inert (events are gated to prod or SENTRY_DEBUG=1).
# DSN: same value works for both; the public one is exposed to the browser.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Sourcemap upload at build time only. SENTRY_AUTH_TOKEN must be a Vercel
# BUILD secret (not exposed at runtime). Without it builds still pass but
# stack traces stay minified.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Set to 1 in .env.local to force-enable Sentry in local dev for testing.
SENTRY_DEBUG=
